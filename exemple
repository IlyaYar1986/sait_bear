<script>
(function () {
  const categories = [
    { name: "Украшения", link: "#jewelry" },
    { name: "Декор", link: "#decor" },
    { name: "Сладости", link: "#sweet" },
    { name: "Угощения", link: "#food" }
  ];

  const sectors = [
    "Украшения",
    "Декор",
    "Сладости",
    "Угощения",
    "Украшения",
    "Сладости",
    "Декор",
    "Угощения",
    "Украшения",
    "Декор",
    "Сладости",
    "Угощения",
    "Украшения",
    "Сладости",
    "Декор",
    "Угощения",
    "Украшения",
    "Декор",
    "Сладости",
    "Угощения",
    "Украшения",
    "Сладости",
    "Декор",
    "Угощения",
    "Украшения"
  ];

  const palette = {
    "Украшения": {
      base: "#7a5543",
      line: "rgba(243,223,182,0.18)",
      dot: "rgba(243,223,182,0.14)"
    },
    "Декор": {
      base: "#684536",
      line: "rgba(241,216,179,0.16)",
      dot: "rgba(241,216,179,0.13)"
    },
    "Сладости": {
      base: "#8a624b",
      line: "rgba(249,223,182,0.18)",
      dot: "rgba(249,223,182,0.14)"
    },
    "Угощения": {
      base: "#58392d",
      line: "rgba(238,211,168,0.16)",
      dot: "rgba(238,211,168,0.13)"
    }
  };

  const canvas = document.getElementById("totemWheelCanvas");
  const ctx = canvas.getContext("2d");
  const spinBtn = document.getElementById("totemSpinBtn");
  const resultBox = document.getElementById("totemResultBox");
  const resultText = document.getElementById("totemResultText");
  const followBtn = document.getElementById("followBtn");
  const chooseBtn = document.getElementById("chooseBtn");

  const size = 420;
  const center = size / 2;
  const radius = 188;
  const sectorCount = sectors.length;
  const arc = (Math.PI * 2) / sectorCount;

  let currentRotation = 0;
  let isSpinning = false;

  function drawWheel() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    drawOuterOrnament();

    for (let i = 0; i < sectorCount; i++) {
      const startAngle = i * arc - Math.PI / 2;
      const endAngle = startAngle + arc;
      const label = sectors[i];
      const colors = palette[label] || palette["Украшения"];

      drawSector(startAngle, endAngle, colors.base);
      drawSectorCarving(startAngle, endAngle, colors.line, colors.dot);
      drawSectorText(startAngle, label);
    }

    drawInnerRings();
  }

  function drawOuterOrnament() {
    ctx.save();
    ctx.translate(center, center);

    ctx.beginPath();
    ctx.arc(0, 0, radius + 6, 0, Math.PI * 2);
    ctx.strokeStyle = "rgba(240,214,171,0.13)";
    ctx.lineWidth = 2;
    ctx.stroke();

    ctx.beginPath();
    ctx.arc(0, 0, radius - 12, 0, Math.PI * 2);
    ctx.strokeStyle = "rgba(255,255,255,0.04)";
    ctx.lineWidth = 1;
    ctx.stroke();

    for (let i = 0; i < 50; i++) {
      const a = (Math.PI * 2 / 50) * i;
      const r = radius + 1;
      const x = Math.cos(a) * r;
      const y = Math.sin(a) * r;

      ctx.beginPath();
      ctx.arc(x, y, 1.7, 0, Math.PI * 2);
      ctx.fillStyle = "rgba(239,213,169,0.20)";
      ctx.fill();
    }

    ctx.restore();
  }

  function drawSector(startAngle, endAngle, fill) {
    ctx.beginPath();
    ctx.moveTo(center, center);
    ctx.arc(center, center, radius, startAngle, endAngle);
    ctx.closePath();
    ctx.fillStyle = fill;
    ctx.fill();

    ctx.strokeStyle = "rgba(245,225,190,0.14)";
    ctx.lineWidth = 1.1;
    ctx.stroke();
  }

  function drawSectorCarving(startAngle, endAngle, lineColor, dotColor) {
    const mid = startAngle + (endAngle - startAngle) / 2;

    ctx.save();
    ctx.translate(center, center);
    ctx.rotate(mid);

    ctx.strokeStyle = lineColor;
    ctx.lineWidth = 1;

    for (let r = 52; r <= 160; r += 24) {
      ctx.beginPath();
      ctx.arc(0, 0, r, -0.09, 0.09);
      ctx.stroke();
    }

    for (let r = 70; r <= 154; r += 28) {
      ctx.beginPath();
      ctx.arc(r, 0, 2, 0, Math.PI * 2);
      ctx.fillStyle = dotColor;
      ctx.fill();
    }

    ctx.beginPath();
    ctx.moveTo(46, 0);
    ctx.bezierCurveTo(70, -10, 98, -10, 120, 0);
    ctx.bezierCurveTo(98, 10, 70, 10, 46, 0);
    ctx.strokeStyle = lineColor;
    ctx.stroke();

    ctx.beginPath();
    ctx.moveTo(86, 0);
    ctx.bezierCurveTo(96, -6, 108, -6, 118, 0);
    ctx.bezierCurveTo(108, 6, 96, 6, 86, 0);
    ctx.stroke();

    ctx.restore();
  }

  function drawSectorText(startAngle, label) {
    ctx.save();
    ctx.translate(center, center);
    ctx.rotate(startAngle + arc / 2);

    ctx.textAlign = "right";
    ctx.fillStyle = "#f5e6ca";
    ctx.font = "bold 12px Georgia";

    const shortLabel = shorten(label);
    ctx.fillText(shortLabel, radius - 18, 4);

    ctx.restore();
  }

  function drawInnerRings() {
    ctx.save();
    ctx.translate(center, center);

    ctx.beginPath();
    ctx.arc(0, 0, 62, 0, Math.PI * 2);
    ctx.strokeStyle = "rgba(240,214,171,0.14)";
    ctx.lineWidth = 1.4;
    ctx.stroke();

    ctx.beginPath();
    ctx.arc(0, 0, 78, 0, Math.PI * 2);
    ctx.strokeStyle = "rgba(255,255,255,0.04)";
    ctx.lineWidth = 1;
    ctx.stroke();

    for (let i = 0; i < 20; i++) {
      const a = (Math.PI * 2 / 20) * i;
      const x = Math.cos(a) * 70;
      const y = Math.sin(a) * 70;

      ctx.beginPath();
      ctx.arc(x, y, 1.8, 0, Math.PI * 2);
      ctx.fillStyle = "rgba(240,214,171,0.14)";
      ctx.fill();
    }

    ctx.restore();
  }

  function shorten(text) {
    return text;
  }

  function getCategoryLink(categoryName) {
    const found = categories.find(item => item.name === categoryName);
    return found ? found.link : "#";
  }

  function spinWheel() {
    if (isSpinning) return;

    isSpinning = true;
    spinBtn.disabled = true;
    resultBox.style.display = "none";

    const winnerIndex = Math.floor(Math.random() * sectorCount);
    const sectorAngle = 360 / sectorCount;

    const targetAngle = 360 - (winnerIndex * sectorAngle + sectorAngle / 2);
    const currentNormalized = ((currentRotation % 360) + 360) % 360;
    const deltaToTarget = ((targetAngle - currentNormalized) + 360) % 360;
    const extraSpins = 360 * (6 + Math.floor(Math.random() * 3));
    const totalRotation = extraSpins + deltaToTarget;

    currentRotation += totalRotation;
    canvas.style.transform = `rotate(${currentRotation}deg)`;

    setTimeout(() => {
      const winner = sectors[winnerIndex];

      resultText.textContent = `Хранитель ведёт тебя к этим сокровищам: ${winner}`;
      followBtn.href = getCategoryLink(winner);
      chooseBtn.href = "#choose-path";

      resultBox.style.display = "block";
      isSpinning = false;
      spinBtn.disabled = false;
    }, 5900);
  }

  drawWheel();
  spinBtn.addEventListener("click", spinWheel);
})();
</script>



